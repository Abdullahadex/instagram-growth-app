# Instagram API Configuration
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret
INSTAGRAM_ACCESS_TOKEN=your_access_token
INSTAGRAM_USER_ID=your_instagram_user_id
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_business_account_id

# Database Configuration (for storing automation data)
DATABASE_URL=mongodb://localhost:27017/instagrow
# or for PostgreSQL: postgresql://username:password@localhost:5432/instagrow

# App Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_key

# Third-party APIs (optional but recommended)
RAPID_API_KEY=your_rapid_api_key_for_hashtag_research
OPENAI_API_KEY=your_openai_api_key_for_ai_content

# Webhook URLs (for Instagram webhooks)
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

